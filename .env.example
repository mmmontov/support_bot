# API
DATABASE_URL=sqlite+aiosqlite:///./support.db
API_SECRET=generate-a-long-random-string
API_HOST=127.0.0.1
API_PORT=8000

# Bot (local: same host; Docker Compose overrides API_BASE_URL to http://api:8000)
BOT_TOKEN=123456:ABC...
API_BASE_URL=http://127.0.0.1:8000
ADMIN_CHAT_ID=-1001234567890

# Docker: copy this file to .env, then: docker compose up -d
# DB file lives in volume /data; API_PORT below maps host port to container 8000
